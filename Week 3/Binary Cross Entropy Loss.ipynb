    "import numpy as np"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "b031c035-6337-4518-b538-4edf3c5332ad",
   "metadata": {},
   "outputs": [],
   "source": [
    "def bce_loss(y_true, y_pred):\n",
    "    y_pred = np.clip(y_pred, 1e-7, 1-1e-7)\n",
    "    return np.mean(\n",
    "        y_true * np.log(y_pred) + (1- y_true) * np.log(1-y_pred)\n",
    "    )"
   ]
  },
